@inject ILocalizationService Loc
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">@Loc["brand"]</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="knowledge" Match="NavLinkMatch.All">
                <span class="bi bi-diagram-3-fill-nav-menu" aria-hidden="true"></span> @Loc["nav.knowledge"]
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="entities">
                <span class="bi bi-share-fill-nav-menu" aria-hidden="true"></span> Entities
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="quality">
                <span class="bi bi-heart-pulse-fill-nav-menu" aria-hidden="true"></span> @Loc["nav.quality"]
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tdk">
                <span class="bi bi-patch-check-fill-nav-menu" aria-hidden="true"></span> TDK
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="embeddings">
                <span class="bi bi-grid-3x3-gap-fill-nav-menu" aria-hidden="true"></span> Embeddings
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="sources">
                <span class="bi bi-folder2-open-nav-menu" aria-hidden="true"></span> @Loc["nav.sources"]
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="import">
                <span class="bi bi-boxes-nav-menu" aria-hidden="true"></span> @Loc["nav.import"]
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="settings">
                <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> @Loc["nav.settings"]
            </NavLink>
        </div>
    </nav>
</div>

<div class="nav-footer px-3">
    <ThemeToggle />
    <LanguageToggle />
</div>

@code {
    /// <summary>Subscribes to locale changes so nav labels re-render when language is switched.</summary>
    protected override void OnInitialized() => Loc.OnLanguageChanged += StateHasChanged;

    /// <summary>Unsubscribes to prevent memory leaks.</summary>
    public void Dispose() => Loc.OnLanguageChanged -= StateHasChanged;
}
