@page "/tdk"
@rendermode InteractiveServer
@inject IKnowledgeGraph KnowledgeGraph
@inject ITdkEngine TdkEngine
@inject ITdkFixtureVerifier FixtureVerifier
@inject ITdkDryRunService DryRun
@inject IIdentityContext Identity
@inject ILocalizationService Loc
@implements IDisposable

<PageTitle>@Loc["page.tdk"]</PageTitle>

<h3 class="mb-2">@Loc["tdk.heading"]</h3>
<p style="font-size:0.85rem;color:#94a3b8;">
    @Loc["tdk.desc"]
</p>

<div class="mb-3" style="max-width:900px;">
    <label class="form-label" style="font-size:0.8rem;">@Loc["tdk.task.label"]</label>
    <input class="form-control form-control-sm mb-2" @bind="_task"
           placeholder="@Loc["tdk.task.placeholder"]" />

    <label class="form-label" style="font-size:0.8rem;">@Loc["tdk.code.label"]</label>
    <textarea class="form-control form-control-sm" style="font-family:monospace;" rows="12"
              @bind="_code" placeholder="@Loc["tdk.code.placeholder"]"></textarea>

    <button class="btn btn-sm btn-primary mt-2" @onclick="ValidateAsync" disabled="@_running">
        @(_running ? Loc["tdk.btn.validating"] : Loc["tdk.btn.validate"])
    </button>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger" style="max-width:900px;">@_error</div>
}

@if (_result is not null)
{
    <div style="font-size:0.82rem;color:#94a3b8;" class="mb-2">
        @string.Format(Loc["tdk.rulecount"], _activeRuleCount)
    </div>

    @if (!_result.HasViolations)
    {
        <div class="alert alert-success" style="max-width:900px;">@Loc["tdk.noviolations"]</div>
    }
    else
    {
        <table class="table table-sm" style="max-width:900px;">
            <thead>
                <tr>
                    <th>@Loc["tdk.col.rule"]</th>
                    <th>@Loc["tdk.col.severity"]</th>
                    <th>@Loc["tdk.col.line"]</th>
                    <th>@Loc["tdk.col.message"]</th>
                    <th>@Loc["tdk.col.suggestion"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in _result.Violations)
                {
                    <tr>
                        <td><code>@v.RuleId</code></td>
                        <td>@v.Severity</td>
                        <td>@(v.Line?.ToString() ?? "—")</td>
                        <td>@v.Message</td>
                        <td>@(string.IsNullOrWhiteSpace(v.Suggestion) ? "—" : v.Suggestion)</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_result.HasEngineErrors)
    {
        <div class="alert alert-warning" style="max-width:900px;">
            <strong>@Loc["tdk.engine.heading"]</strong> — @Loc["tdk.engine.subtext"]
            <ul class="mb-0">
                @foreach (var e in _result.EngineErrors)
                {
                    <li>
                        <code>@e.RuleId</code>: @e.Reason
                        @if (e.ExitCode is int ec) { <text> (@Loc["tdk.engine.exitcode"] @ec)</text> }
                        @if (e.TimedOut) { <text> (@Loc["tdk.engine.timeout"])</text> }
                    </li>
                }
            </ul>
        </div>
    }
}

<hr class="my-3" style="max-width:900px;" />

<h4 class="mb-2" style="font-size:1rem;">@Loc["tdk.fixtures.heading"]</h4>
<p style="font-size:0.82rem;color:#94a3b8;">@Loc["tdk.fixtures.desc"]</p>
<button class="btn btn-sm btn-outline-primary mb-2" @onclick="RunFixturesAsync" disabled="@_fxRunning">
    @(_fxRunning ? Loc["tdk.fixtures.running"] : Loc["tdk.fixtures.btn"])
</button>

@if (_fxError is not null)
{
    <div class="alert alert-danger" style="max-width:900px;">@_fxError</div>
}

@if (_fxReport is not null)
{
    @if (_fxReport.TotalCount == 0)
    {
        <div class="alert alert-secondary" style="max-width:900px;">@Loc["tdk.fixtures.none"]</div>
    }
    else
    {
        <table class="table table-sm" style="max-width:900px;">
            <thead>
                <tr>
                    <th>@Loc["tdk.fixtures.col.rule"]</th>
                    <th>@Loc["tdk.fixtures.col.pass"]</th>
                    <th>@Loc["tdk.fixtures.col.fail"]</th>
                    <th>@Loc["tdk.fixtures.col.status"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _fxReport.Rules)
                {
                    var passCases = r.Cases.Where(c => c.Kind == "pass").ToList();
                    var failCases = r.Cases.Where(c => c.Kind == "fail").ToList();
                    var allEngine = r.Cases.Count > 0 && r.Cases.All(c => c.EngineError);
                    <tr>
                        <td><code>@r.RuleId</code></td>
                        <td>@(passCases.Count(c => c.Ok)) / @(passCases.Count)</td>
                        <td>@(failCases.Count(c => c.Ok)) / @(failCases.Count)</td>
                        <td>
                            @if (allEngine)
                            {
                                <span style="color:#f59e0b;">@Loc["tdk.fixtures.nosandbox"]</span>
                            }
                            else if (r.Verified)
                            {
                                <span style="color:#22c55e;">@Loc["tdk.fixtures.verified"]</span>
                            }
                            else
                            {
                                <span style="color:#ef4444;">@Loc["tdk.fixtures.failed"]</span>
                            }
                        </td>
                    </tr>
                    @foreach (var c in r.Cases.Where(c => !c.Ok))
                    {
                        <tr>
                            <td></td>
                            <td colspan="3" style="font-size:0.8rem;color:#94a3b8;">
                                <code>@($"{c.Kind} #{c.Index}")</code> — @c.Detail
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
}

<hr class="my-3" style="max-width:900px;" />

<h4 class="mb-2" style="font-size:1rem;">@Loc["tdk.dryrun.heading"]</h4>
<p style="font-size:0.82rem;color:#94a3b8;">@Loc["tdk.dryrun.desc"]</p>

<div class="mb-3" style="max-width:900px;">
    <label class="form-label" style="font-size:0.8rem;">@Loc["tdk.dryrun.script.label"]</label>
    <textarea class="form-control form-control-sm mb-2" style="font-family:monospace;" rows="10"
              @bind="_drScript" placeholder="from tdk import validator, violation"></textarea>

    <label class="form-label" style="font-size:0.8rem;">@Loc["tdk.dryrun.code.label"]</label>
    <textarea class="form-control form-control-sm mb-2" style="font-family:monospace;" rows="6"
              @bind="_drCode"></textarea>

    <label class="form-label" style="font-size:0.8rem;">@Loc["tdk.dryrun.lang.label"]</label>
    <input class="form-control form-control-sm mb-2" style="max-width:220px;" @bind="_drLang"
           placeholder="python" />

    <button class="btn btn-sm btn-primary" @onclick="RunDryRunAsync" disabled="@_drRunning">
        @(_drRunning ? Loc["tdk.dryrun.running"] : Loc["tdk.dryrun.btn"])
    </button>
</div>

@if (_drError is not null)
{
    <div class="alert alert-danger" style="max-width:900px;">@_drError</div>
}

@if (_drResult is not null)
{
    <div style="font-size:0.82rem;color:#94a3b8;" class="mb-1">
        @Loc["tdk.dryrun.exit"]: <code>@_drResult.ExitCode</code>
        @if (_drResult.TimedOut) { <text> (@Loc["tdk.engine.timeout"])</text> }
    </div>

    @if (!string.IsNullOrEmpty(_drResult.Stdout))
    {
        <div style="font-size:0.78rem;color:#94a3b8;">@Loc["tdk.dryrun.stdout"]</div>
        <pre style="max-width:900px;white-space:pre-wrap;background:#0f172a;color:#e2e8f0;padding:0.5rem;font-size:0.8rem;">@_drResult.Stdout</pre>
    }

    @if (!string.IsNullOrEmpty(_drResult.Stderr))
    {
        <div style="font-size:0.78rem;color:#94a3b8;">@Loc["tdk.dryrun.stderr"]</div>
        <pre style="max-width:900px;white-space:pre-wrap;background:#1e1b1b;color:#fca5a5;padding:0.5rem;font-size:0.8rem;">@_drResult.Stderr</pre>
    }

    @if (_drResult.OutputParsed)
    {
        @if (_drResult.Violations.Count > 0)
        {
            <table class="table table-sm" style="max-width:900px;">
                <thead>
                    <tr>
                        <th>@Loc["tdk.col.rule"]</th>
                        <th>@Loc["tdk.col.severity"]</th>
                        <th>@Loc["tdk.col.line"]</th>
                        <th>@Loc["tdk.col.message"]</th>
                        <th>@Loc["tdk.col.suggestion"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in _drResult.Violations)
                    {
                        <tr>
                            <td><code>@v.RuleId</code></td>
                            <td>@v.Severity</td>
                            <td>@(v.Line?.ToString() ?? "—")</td>
                            <td>@v.Message</td>
                            <td>@(string.IsNullOrWhiteSpace(v.Suggestion) ? "—" : v.Suggestion)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-success" style="max-width:900px;">@Loc["tdk.noviolations"]</div>
        }
    }
    else
    {
        <div class="alert alert-secondary" style="max-width:900px;">@Loc["tdk.dryrun.unparsed"]</div>
    }
}

@code {
    private string _task = "";
    private string _code = "";
    private bool _running;
    private string? _error;
    private TdkResult? _result;
    private int _activeRuleCount;

    private bool _fxRunning;
    private string? _fxError;
    private TdkFixtureVerificationReport? _fxReport;

    private string _drScript = "";
    private string _drCode = "";
    private string _drLang = "";
    private bool _drRunning;
    private string? _drError;
    private TdkDryRunResult? _drResult;

    protected override void OnInitialized() => Loc.OnLanguageChanged += StateHasChanged;

    public void Dispose() => Loc.OnLanguageChanged -= StateHasChanged;

    private async Task ValidateAsync()
    {
        _running = true;
        _error = null;
        _result = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_code))
            {
                _error = Loc["tdk.error.nocode"];
                return;
            }

            var query = string.IsNullOrWhiteSpace(_task) ? _code : _task;

            var taskContext = new TaskContext
            {
                Task = query,
                Concepts = ExtractConcepts(query),
                UserId = Identity.UserId
            };
            var akgContext = await KnowledgeGraph.CompileContextAsync(taskContext);
            _activeRuleCount = akgContext.ActiveRules.Count;

            var request = new AgentRequest
            {
                UserMessage = query,
                ConversationId = "ui-tdk",
                Identity = Identity
            };

            _result = await TdkEngine.ValidateAsync(_code, akgContext.ActiveRules, request);
        }
        catch (Exception ex)
        {
            // Most likely a missing sandbox (no Docker / TDK_SANDBOX_TYPE) — surface it readably.
            _error = string.Format(Loc["tdk.error.failed"], ex.Message);
        }
        finally
        {
            _running = false;
        }
    }

    private async Task RunFixturesAsync()
    {
        _fxRunning = true;
        _fxError = null;
        _fxReport = null;

        try
        {
            _fxReport = await FixtureVerifier.VerifyAllAsync();
        }
        catch (Exception ex)
        {
            _fxError = string.Format(Loc["tdk.fixtures.error"], ex.Message);
        }
        finally
        {
            _fxRunning = false;
        }
    }

    private async Task RunDryRunAsync()
    {
        _drRunning = true;
        _drError = null;
        _drResult = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_drScript))
            {
                _drError = Loc["tdk.dryrun.noscript"];
                return;
            }

            var lang = string.IsNullOrWhiteSpace(_drLang) ? null : _drLang.Trim();
            _drResult = await DryRun.RunAsync(_drScript, _drCode, lang);
        }
        catch (Exception ex)
        {
            _drError = string.Format(Loc["tdk.dryrun.error"], ex.Message);
        }
        finally
        {
            _drRunning = false;
        }
    }

    /// <summary>Extracts concept tokens for AKG relevance scoring (mirrors the tdk_validate tool).</summary>
    private static IReadOnlyList<string> ExtractConcepts(string message)
        => message.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                  .Select(w => w.Trim('.', ',', '!', '?', '"', '\'').ToLowerInvariant())
                  .Where(w => w.Length > 3)
                  .Distinct()
                  .Take(20)
                  .ToList();
}
