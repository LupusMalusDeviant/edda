@page "/tdk"
@rendermode InteractiveServer
@inject IKnowledgeGraph KnowledgeGraph
@inject ITdkEngine TdkEngine
@inject IIdentityContext Identity
@inject ILocalizationService Loc
@implements IDisposable

<PageTitle>@Loc["page.tdk"]</PageTitle>

<h3 class="mb-2">@Loc["tdk.heading"]</h3>
<p style="font-size:0.85rem;color:#94a3b8;">
    @Loc["tdk.desc"]
</p>

<div class="mb-3" style="max-width:900px;">
    <label class="form-label" style="font-size:0.8rem;">@Loc["tdk.task.label"]</label>
    <input class="form-control form-control-sm mb-2" @bind="_task"
           placeholder="@Loc["tdk.task.placeholder"]" />

    <label class="form-label" style="font-size:0.8rem;">@Loc["tdk.code.label"]</label>
    <textarea class="form-control form-control-sm" style="font-family:monospace;" rows="12"
              @bind="_code" placeholder="@Loc["tdk.code.placeholder"]"></textarea>

    <button class="btn btn-sm btn-primary mt-2" @onclick="ValidateAsync" disabled="@_running">
        @(_running ? Loc["tdk.btn.validating"] : Loc["tdk.btn.validate"])
    </button>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger" style="max-width:900px;">@_error</div>
}

@if (_result is not null)
{
    <div style="font-size:0.82rem;color:#94a3b8;" class="mb-2">
        @string.Format(Loc["tdk.rulecount"], _activeRuleCount)
    </div>

    @if (!_result.HasViolations)
    {
        <div class="alert alert-success" style="max-width:900px;">@Loc["tdk.noviolations"]</div>
    }
    else
    {
        <table class="table table-sm" style="max-width:900px;">
            <thead>
                <tr>
                    <th>@Loc["tdk.col.rule"]</th>
                    <th>@Loc["tdk.col.severity"]</th>
                    <th>@Loc["tdk.col.line"]</th>
                    <th>@Loc["tdk.col.message"]</th>
                    <th>@Loc["tdk.col.suggestion"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in _result.Violations)
                {
                    <tr>
                        <td><code>@v.RuleId</code></td>
                        <td>@v.Severity</td>
                        <td>@(v.Line?.ToString() ?? "—")</td>
                        <td>@v.Message</td>
                        <td>@(string.IsNullOrWhiteSpace(v.Suggestion) ? "—" : v.Suggestion)</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_result.HasEngineErrors)
    {
        <div class="alert alert-warning" style="max-width:900px;">
            <strong>@Loc["tdk.engine.heading"]</strong> — @Loc["tdk.engine.subtext"]
            <ul class="mb-0">
                @foreach (var e in _result.EngineErrors)
                {
                    <li>
                        <code>@e.RuleId</code>: @e.Reason
                        @if (e.ExitCode is int ec) { <text> (@Loc["tdk.engine.exitcode"] @ec)</text> }
                        @if (e.TimedOut) { <text> (@Loc["tdk.engine.timeout"])</text> }
                    </li>
                }
            </ul>
        </div>
    }
}

@code {
    private string _task = "";
    private string _code = "";
    private bool _running;
    private string? _error;
    private TdkResult? _result;
    private int _activeRuleCount;

    protected override void OnInitialized() => Loc.OnLanguageChanged += StateHasChanged;

    public void Dispose() => Loc.OnLanguageChanged -= StateHasChanged;

    private async Task ValidateAsync()
    {
        _running = true;
        _error = null;
        _result = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_code))
            {
                _error = Loc["tdk.error.nocode"];
                return;
            }

            var query = string.IsNullOrWhiteSpace(_task) ? _code : _task;

            var taskContext = new TaskContext
            {
                Task = query,
                Concepts = ExtractConcepts(query),
                UserId = Identity.UserId
            };
            var akgContext = await KnowledgeGraph.CompileContextAsync(taskContext);
            _activeRuleCount = akgContext.ActiveRules.Count;

            var request = new AgentRequest
            {
                UserMessage = query,
                ConversationId = "ui-tdk",
                Identity = Identity
            };

            _result = await TdkEngine.ValidateAsync(_code, akgContext.ActiveRules, request);
        }
        catch (Exception ex)
        {
            // Most likely a missing sandbox (no Docker / TDK_SANDBOX_TYPE) — surface it readably.
            _error = string.Format(Loc["tdk.error.failed"], ex.Message);
        }
        finally
        {
            _running = false;
        }
    }

    /// <summary>Extracts concept tokens for AKG relevance scoring (mirrors the tdk_validate tool).</summary>
    private static IReadOnlyList<string> ExtractConcepts(string message)
        => message.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                  .Select(w => w.Trim('.', ',', '!', '?', '"', '\'').ToLowerInvariant())
                  .Where(w => w.Length > 3)
                  .Distinct()
                  .Take(20)
                  .ToList();
}
