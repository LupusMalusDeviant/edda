@page "/embeddings"
@rendermode InteractiveServer
@using Edda.Security.Credentials
@inject IEmbeddingService EmbeddingService
@inject IKnowledgeGraph KnowledgeGraph
@inject ISettingsService SettingsService
@inject ICredentialStore Credentials
@inject IIdentityContext Identity
@inject IAuditLog Audit
@inject IProviderProbe Probe
@inject ILocalizationService Loc
@implements IDisposable

<PageTitle>@Loc["page.embeddings"]</PageTitle>

<h3 class="mb-3">@Loc["emb.heading"]</h3>

<div class="card mb-3" style="max-width:700px;">
    <div class="card-body">
        <h6 class="card-title">@Loc["emb.status"]</h6>
        <table class="table table-sm mb-0">
            <tbody>
                <tr>
                    <td style="width:40%;">@Loc["emb.status.provider"]</td>
                    <td><code>@(_provider)</code></td>
                </tr>
                <tr>
                    <td>@Loc["emb.status.available"]</td>
                    <td>@(EmbeddingService.IsAvailable ? Loc["emb.status.yes"] : Loc["emb.status.no"])</td>
                </tr>
                <tr>
                    <td>@Loc["emb.status.dimensions"]</td>
                    <td>@EmbeddingService.Dimensions</td>
                </tr>
                @if (_stats is not null)
                {
                    <tr>
                        <td>@Loc["emb.status.embedded"]</td>
                        <td>@_stats.RulesWithEmbeddings / @_stats.TotalRules</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card mb-3" style="max-width:700px;">
    <div class="card-body">
        <h6 class="card-title">@Loc["emb.config"]</h6>
        <p class="form-text mt-0">
            @Loc["emb.config.desc"]
        </p>

        <div class="mb-2">
            <label class="form-label" for="emb-provider">@Loc["emb.provider.label"]</label>
            <select id="emb-provider" class="form-select form-select-sm" @bind="_cfgProvider" @bind:after="RefreshKeyStatusAsync">
                <option value="null">@Loc["emb.provider.null"]</option>
                <option value="openai">OpenAI</option>
                <option value="google">Google</option>
                <option value="voyage">Voyage</option>
                <option value="ollama">Ollama</option>
                <option value="custom">@Loc["emb.provider.custom"]</option>
                <option value="bedrock">AWS Bedrock</option>
            </select>
        </div>
        <div class="mb-2">
            <label class="form-label" for="emb-model">@Loc["config.label.model"]</label>
            <input id="emb-model" class="form-control form-control-sm" @bind="_cfgModel" list="emb-models"
                   placeholder="@Loc["emb.placeholder.default"]" />
            @if (_embModels.Count > 0)
            {
                <datalist id="emb-models">
                    @foreach (var m in _embModels)
                    {
                        <option value="@m" />
                    }
                </datalist>
            }
            <div class="form-text">
                @((MarkupString)Loc["emb.model.hint"])
            </div>
        </div>
        <div class="mb-2">
            <label class="form-label" for="emb-baseurl">@Loc["emb.baseurl"]</label>
            <input id="emb-baseurl" class="form-control form-control-sm" @bind="_cfgBaseUrl" placeholder="@Loc["emb.placeholder.default"]" />
            @if (_cfgProvider == "ollama")
            {
                <div class="form-text">
                    @((MarkupString)Loc["emb.baseurl.ollamahint"])
                </div>
            }
        </div>
        <div class="mb-2">
            <label class="form-label" for="emb-dims">@Loc["emb.status.dimensions"]</label>
            <input id="emb-dims" type="number" class="form-control form-control-sm" @bind="_cfgDimensions"
                   placeholder="@Loc["emb.placeholder.default"]" />
        </div>
        @if (_cfgProvider == "bedrock")
        {
            <div class="mb-2">
                <label class="form-label" for="emb-region">@Loc["emb.aws.region"]</label>
                <input id="emb-region" class="form-control form-control-sm" @bind="_cfgRegion" placeholder="us-east-1" />
            </div>
            <div class="mb-2">
                <label class="form-label" for="emb-access">@Loc["emb.aws.accesskey"]</label>
                <input id="emb-access" class="form-control form-control-sm" @bind="_cfgAccessKey"
                       placeholder="@(_accessKeyStored ? Loc["emb.secret.stored"] : Loc["emb.aws.accesskey.placeholder"])" />
            </div>
        }
        <div class="mb-2">
            <label class="form-label" for="emb-key">@KeyLabel</label>
            <input id="emb-key" type="password" class="form-control form-control-sm" @bind="_cfgKey"
                   placeholder="@KeyPlaceholder" />
        </div>

        <div class="alert alert-warning py-2" style="font-size:0.85rem;">
            @((MarkupString)Loc["emb.warn.stale"])
        </div>

        <button class="btn btn-sm btn-primary" @onclick="SaveConfigAsync" disabled="@_savingConfig">
            @(_savingConfig ? Loc["emb.btn.saving"] : Loc["emb.btn.save"])
        </button>
        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="TestEmbeddingAsync" disabled="@_testingEmb">
            @(_testingEmb ? Loc["emb.btn.testing"] : Loc["emb.btn.test"])
        </button>
        @if (_configSaved)
        {
            <span class="text-success ms-2" style="font-size:0.85rem;">@Loc["emb.saved"]</span>
        }
        @if (_embTestResult is not null)
        {
            <div class="alert @(_embTestOk ? "alert-success" : "alert-danger") mt-2 mb-0 py-1">@_embTestResult</div>
        }
    </div>
</div>

<div class="card mb-3" style="max-width:700px;">
    <div class="card-body">
        <h6 class="card-title">@Loc["emb.chunking"]</h6>
        <p class="form-text mt-0">
            @Loc["emb.chunking.desc"]
        </p>

        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="chunk-enabled" @bind="_chunkEnabled" />
            <label class="form-check-label" for="chunk-enabled">@Loc["emb.chunking.enabled"]</label>
        </div>
        <div class="mb-2">
            <label class="form-label" for="chunk-max">@Loc["emb.chunking.max"]</label>
            <input id="chunk-max" type="number" class="form-control form-control-sm" @bind="_chunkMaxChars"
                   placeholder="@string.Format(Loc["emb.chunking.default"], ChunkingOptions.DefaultMaxChars)" />
        </div>
        <div class="mb-2">
            <label class="form-label" for="chunk-overlap">@Loc["emb.chunking.overlap"]</label>
            <input id="chunk-overlap" type="number" class="form-control form-control-sm" @bind="_chunkOverlap"
                   placeholder="@string.Format(Loc["emb.chunking.default"], ChunkingOptions.DefaultOverlapChars)" />
        </div>

        <div class="alert alert-warning py-2" style="font-size:0.85rem;">
            @((MarkupString)Loc["emb.chunking.warn"])
        </div>

        <button class="btn btn-sm btn-primary" @onclick="SaveChunkingAsync" disabled="@_savingChunking">
            @(_savingChunking ? Loc["emb.btn.saving"] : Loc["emb.btn.save"])
        </button>
        @if (_chunkingSaved)
        {
            <span class="text-success ms-2" style="font-size:0.85rem;">@Loc["emb.saved"]</span>
        }
    </div>
</div>

@if (_stats is { EmbeddingRebuildRunning: true })
{
    <div class="mb-3" style="max-width:700px;">
        <div style="font-size:0.85rem;color:#fbbf24;" class="mb-1">
            @string.Format(Loc["emb.rebuild.progress"], _stats.EmbeddingRebuildDone, _stats.EmbeddingRebuildTotal)
            @if (_stats.EmbeddingRebuildCurrentRule is not null)
            {
                <span style="opacity:0.6;"> — @_stats.EmbeddingRebuildCurrentRule</span>
            }
        </div>
        <div style="height:8px;background:#1e293b;border-radius:4px;overflow:hidden;">
            <div style="width:@(Percent)%;height:100%;background:#fbbf24;border-radius:4px;transition:width 0.5s;"></div>
        </div>
        <button class="btn btn-sm btn-outline-danger mt-2" @onclick="CancelRebuild">@Loc["sources.btn.cancel"]</button>
    </div>
}

@if (_stats is not null)
{
    <div class="mb-3" style="font-size:0.85rem;color:#94a3b8;max-width:700px;">
        @Loc["emb.coverage.label"] <strong style="color:#e2e8f0;">@_stats.RulesWithEmbeddings</strong> / @_stats.TotalRules @Loc["emb.coverage.rules"]
        @if (_stats.PendingEmbeddingCount > 0)
        {
            <span> · @_stats.PendingEmbeddingCount @Loc["emb.coverage.pending"]</span>
        }
        @if (_stats.FailedEmbeddingCount > 0)
        {
            <span class="text-danger"> · @_stats.FailedEmbeddingCount @Loc["emb.coverage.failed"]</span>
        }
        @if (_stats.TotalHeads > 0)
        {
            <div class="mt-1">@Loc["emb.coverage.heads"] <strong style="color:#e2e8f0;">@_stats.HeadsWithVectors</strong> / @_stats.TotalHeads @Loc["emb.coverage.repos"]</div>
        }
    </div>
}

<button class="btn btn-sm btn-primary" @onclick="Rebuild"
        disabled="@(_stats is { EmbeddingRebuildRunning: true } || !EmbeddingService.IsAvailable)">
    @Loc["emb.rebuild.btn"]
</button>
@if (!EmbeddingService.IsAvailable)
{
    <div class="mt-2" style="font-size:0.8rem;color:#94a3b8;">
        @Loc["emb.noprovider"]
    </div>
}

@code {
    private GraphStats? _stats;
    private string _provider = "null";
    private System.Threading.Timer? _timer;

    private string _cfgProvider = "null";
    private string _cfgModel = "";
    private string _cfgBaseUrl = "";
    private int? _cfgDimensions;
    private string _cfgKey = "";
    private string _cfgRegion = "";
    private string _cfgAccessKey = "";
    private bool _keyStored;
    private bool _accessKeyStored;
    private bool _savingConfig;
    private bool _configSaved;
    private bool _testingEmb;
    private bool _embTestOk;
    private string? _embTestResult;
    private IReadOnlyList<string> _embModels = [];

    private bool _chunkEnabled = true;
    private int? _chunkMaxChars;
    private int? _chunkOverlap;
    private bool _savingChunking;
    private bool _chunkingSaved;

    private string UserId => Identity.UserId ?? "local";

    private string KeyLabel => _cfgProvider switch
    {
        "bedrock" => Loc["emb.key.aws"],
        "ollama" => Loc["emb.key.ollama"],
        _ => Loc["emb.key.default"],
    };

    private string KeyPlaceholder => _keyStored
        ? Loc["emb.secret.stored"]
        : _cfgProvider switch
        {
            "bedrock" => Loc["emb.keyph.aws"],
            "ollama" => Loc["emb.keyph.ollama"],
            _ => Loc["emb.keyph.default"],
        };

    private int Percent => _stats is { EmbeddingRebuildTotal: > 0 }
        ? (int)(100.0 * _stats.EmbeddingRebuildDone / _stats.EmbeddingRebuildTotal)
        : 0;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += StateHasChanged;

        var embedding = (await SettingsService.ReloadAsync()).Embedding;
        _cfgProvider = string.IsNullOrWhiteSpace(embedding.Provider) ? "null" : embedding.Provider;
        _cfgModel = embedding.Model ?? "";
        _cfgBaseUrl = embedding.BaseUrl ?? "";
        _cfgDimensions = embedding.Dimensions;
        _cfgRegion = embedding.Region ?? "";
        _provider = _cfgProvider;

        var chunking = SettingsService.Current.Chunking;
        _chunkEnabled = chunking.Enabled ?? true;
        _chunkMaxChars = chunking.MaxChars;
        _chunkOverlap = chunking.OverlapChars;

        await RefreshKeyStatusAsync();
        await LoadStatsAsync();

        // Poll stats every 5s to reflect live rebuild progress.
        _timer = new System.Threading.Timer(async _ =>
        {
            await LoadStatsAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadStatsAsync()
    {
        try { _stats = await KnowledgeGraph.GetStatsAsync(); }
        catch { /* best-effort */ }
    }

    private async Task RefreshKeyStatusAsync()
    {
        var all = await Credentials.ListAsync();
        _keyStored = all.Contains(CredentialKeyScheme.Scope(UserId, $"embed:{_cfgProvider}"), StringComparer.Ordinal);
        _accessKeyStored = all.Contains(
            CredentialKeyScheme.Scope(UserId, $"embed:{_cfgProvider}:accesskey"), StringComparer.Ordinal);
    }

    private async Task SaveConfigAsync()
    {
        _savingConfig = true;
        _configSaved = false;
        try
        {
            var current = SettingsService.Current;
            var updated = current with
            {
                Embedding = new EmbeddingSettings
                {
                    Provider = _cfgProvider,
                    Model = string.IsNullOrWhiteSpace(_cfgModel) ? null : _cfgModel,
                    BaseUrl = string.IsNullOrWhiteSpace(_cfgBaseUrl) ? null : _cfgBaseUrl,
                    Dimensions = _cfgDimensions,
                    Region = string.IsNullOrWhiteSpace(_cfgRegion) ? null : _cfgRegion,
                }
            };
            await SettingsService.SaveAsync(updated);

            if (!string.IsNullOrEmpty(_cfgKey))
            {
                await Credentials.StoreAsync(CredentialKeyScheme.Scope(UserId, $"embed:{_cfgProvider}"), _cfgKey);
                _cfgKey = "";
            }

            if (_cfgProvider == "bedrock" && !string.IsNullOrEmpty(_cfgAccessKey))
            {
                await Credentials.StoreAsync(
                    CredentialKeyScheme.Scope(UserId, $"embed:{_cfgProvider}:accesskey"), _cfgAccessKey);
                _cfgAccessKey = "";
            }

            await Audit.LogAsync(AuditEvent.ConfigChanged, UserId, $"Embedding settings updated via UI (provider {_cfgProvider})");
            _provider = _cfgProvider;
            await RefreshKeyStatusAsync();
            await LoadStatsAsync();
            _configSaved = true;
        }
        finally
        {
            _savingConfig = false;
        }
    }

    private async Task TestEmbeddingAsync()
    {
        _testingEmb = true;
        _embTestResult = null;
        try
        {
            var apiKey = !string.IsNullOrEmpty(_cfgKey)
                ? _cfgKey
                : await Credentials.RetrieveAsync(CredentialKeyScheme.Scope(UserId, $"embed:{_cfgProvider}"));
            var baseUrl = string.IsNullOrWhiteSpace(_cfgBaseUrl) ? null : _cfgBaseUrl;

            var result = await Probe.ProbeAsync(_cfgProvider, baseUrl, apiKey);
            _embTestOk = result.Ok;
            _embTestResult = result.Message;
            _embModels = result.Models;
        }
        finally
        {
            _testingEmb = false;
        }
    }

    private async Task SaveChunkingAsync()
    {
        _savingChunking = true;
        _chunkingSaved = false;
        try
        {
            var current = SettingsService.Current;
            var updated = current with
            {
                Chunking = new ChunkingSettings
                {
                    Enabled = _chunkEnabled,
                    MaxChars = _chunkMaxChars,
                    OverlapChars = _chunkOverlap,
                }
            };
            await SettingsService.SaveAsync(updated);
            await Audit.LogAsync(
                AuditEvent.ConfigChanged, UserId, $"Chunking settings updated via UI (enabled {_chunkEnabled})");
            _chunkingSaved = true;
        }
        finally
        {
            _savingChunking = false;
        }
    }

    private void Rebuild()
    {
        // Re-embedding can take minutes on CPU — run in the background, the poller shows progress.
        _ = Task.Run(() => KnowledgeGraph.ResetAndRebuildEmbeddingsAsync(CancellationToken.None));
    }

    private void CancelRebuild() => KnowledgeGraph.CancelEmbeddingRebuild();

    public void Dispose()
    {
        _timer?.Dispose();
        Loc.OnLanguageChanged -= StateHasChanged;
    }
}
