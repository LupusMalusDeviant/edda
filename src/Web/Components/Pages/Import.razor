@page "/import"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@inject IKnowledgeImporter Importer
@inject IActivityTracker Activity
@inject ILocalizationService Loc
@implements IDisposable

<PageTitle>@Loc["page.import"]</PageTitle>

<h3 class="mb-3">@Loc["import.heading.import"]</h3>

<div class="card mb-3" style="max-width:700px;">
    <div class="card-body">
        <p class="form-text mt-0">
            @((MarkupString)Loc["import.desc.import"])
        </p>

        <div class="mb-2">
            <label class="form-label" for="imp-domain">@Loc["import.source.label"]</label>
            <input id="imp-domain" class="form-control form-control-sm" @bind="_domain"
                   placeholder="@Loc["import.source.placeholder"]" />
        </div>

        <div class="mb-2">
            <label class="form-label" for="imp-chunk">@Loc["import.chunk.label"]</label>
            <select id="imp-chunk" class="form-select form-select-sm" @bind="_chunkStyle">
                <option value="auto">@Loc["import.chunk.auto"]</option>
                <option value="prose">@Loc["import.chunk.prose"]</option>
                <option value="markdown">@Loc["import.chunk.markdown"]</option>
                <option value="code">@Loc["import.chunk.code"]</option>
                <option value="table">@Loc["import.chunk.table"]</option>
            </select>
            <div class="form-text">
                @Loc["import.chunk.hint"]
            </div>
        </div>

        <div class="mb-2">
            <label class="form-label" for="imp-file">@Loc["import.file.label"]</label>
            <InputFile id="imp-file" class="form-control form-control-sm" OnChange="OnFile"
                       accept=".md,.markdown,.zip,.pdf,.html,.htm,.json,.jsonl,.csv" />
            @if (_fileName is not null)
            {
                <div class="form-text">@Loc["import.file.selected"] <code>@_fileName</code> (@_fileSize @Loc["import.file.bytes"])</div>
            }
        </div>

        <button class="btn btn-sm btn-primary" @onclick="ImportAsync" disabled="@(_busy || _fileName is null)">
            @(_busy ? Loc["import.btn.importing"] : Loc["import.btn.import"])
        </button>

        @if (_result is not null)
        {
            <div class="alert @(_ok ? "alert-success" : "alert-danger") mt-2 mb-0 py-1">@_result</div>
        }

        <div class="form-text mt-2">
            @Loc["import.hint.reembed"]
        </div>
    </div>
</div>

<h3 class="mb-3">@Loc["import.heading.export"]</h3>

<div class="card mb-3" style="max-width:700px;">
    <div class="card-body">
        <p class="form-text mt-0">
            @((MarkupString)Loc["import.desc.export"])
        </p>
        <a class="btn btn-sm btn-outline-secondary" href="/api/knowledge/export"
           download="edda-knowledge-bundle.json">
            @Loc["import.btn.export"]
        </a>
    </div>
</div>

@code {
    private const long MaxBytes = 50L * 1024 * 1024;

    private string _domain = "";
    private string _chunkStyle = "auto";
    private string? _fileName;
    private long _fileSize;
    private IBrowserFile? _file;
    private bool _busy;
    private bool _ok;
    private string? _result;

    protected override void OnInitialized() => Loc.OnLanguageChanged += StateHasChanged;

    public void Dispose() => Loc.OnLanguageChanged -= StateHasChanged;

    private void OnFile(InputFileChangeEventArgs e)
    {
        _file = e.File;
        _fileName = e.File.Name;
        _fileSize = e.File.Size;
        _result = null;
    }

    private async Task ImportAsync()
    {
        if (_file is null)
        {
            return;
        }

        _busy = true;
        _result = null;
        using var cts = new CancellationTokenSource();
        Activity.Report(ActivityKind.Import, ActivityState.Running, _fileName, onCancel: () => cts.Cancel());
        try
        {
            byte[] bytes;
            await using (var stream = _file.OpenReadStream(MaxBytes))
            using (var buffer = new MemoryStream())
            {
                await stream.CopyToAsync(buffer, cts.Token);
                bytes = buffer.ToArray();
            }

            var domain = string.IsNullOrWhiteSpace(_domain) ? null : _domain.Trim();
            var style = _chunkStyle == "auto" ? null : _chunkStyle;
            var result = await Importer.ImportAsync(_file.Name, bytes, domain, style, cts.Token);

            _ok = result.Failed == 0;
            _result = _ok
                ? string.Format(Loc["import.result.ok"], result.Imported, result.Updated, result.Skipped)
                : string.Format(Loc["import.result.fail"], result.Imported, result.Failed,
                    string.Join("; ", result.Errors.Select(x => x.Message)));
            Activity.Report(ActivityKind.Import, _ok ? ActivityState.Succeeded : ActivityState.Failed, _fileName);
        }
        catch (OperationCanceledException)
        {
            _ok = true;
            _result = Loc["import.result.cancelled"];
            Activity.Report(ActivityKind.Import, ActivityState.Succeeded, Loc["import.activity.cancelled"]);
        }
        catch (Exception ex)
        {
            _ok = false;
            _result = string.Format(Loc["import.result.exception"], ex.Message);
            Activity.Report(ActivityKind.Import, ActivityState.Failed, _fileName);
        }
        finally
        {
            _busy = false;
        }
    }
}
