# ── Edda — lokale Konfiguration ──────────────────────────────
# Kopiere diese Datei nach `.env` und passe die Werte an. `.env` ist git-ignoriert.

# ── Netzwerk (Docker-Deploy via install.sh / docker compose) ───────
# Bind-Adresse: 127.0.0.1 = nur lokal · 0.0.0.0 = alle Interfaces (remote erreichbar)
EDDA_BIND=127.0.0.1
EDDA_PORT=8080

# ── Graph-Datenbank ─────────────────────────────────────────────────
# neo4j (Default, nativer Vektorindex) | memgraph (leichter, App-seitiger Cosine-Fallback)
GRAPH_PROVIDER=neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=none
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ── Embeddings ──────────────────────────────────────────────────────
# Provider: openai | google | voyage | ollama | custom | bedrock | null
# null = ohne semantische Suche (reines Keyword-Retrieval, kein API-Key nötig).
EMBEDDING_PROVIDER=null
OPENAI_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=
# Generischer Fallback-Key (greift für jeden HTTP-Provider, wenn der spezifische leer ist).
# Für bedrock: AWS Secret Access Key.
EMBEDDING_API_KEY=
# Für ollama/custom (lokales Embedding). Stack-internes Ollama (install.sh/ps1 "Lokales Embedding"):
#   COMPOSE_PROFILES=local-embeddings · EMBEDDING_PROVIDER=ollama · EMBEDDING_BASE_URL=http://ollama:11434
#   Modell dann z. B. bge-m3 (wird vom Skript via `ollama pull` gezogen).
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=
# Für bedrock (AWS): Region + Access Key ID. Bleiben beide AWS-Werte leer, nutzt das SDK die
# Default-Credential-Chain (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY, Profil oder Instanz-Rolle).
EMBEDDING_REGION=
EMBEDDING_ACCESS_KEY_ID=

# ── Chunking (adaptive Dokument-Zerlegung) ──────────────────────────
# Grosse Dokumente werden vor dem Embedding nach Stil (Prosa/Markdown/Code/Tabellen) in Chunks zerlegt.
# Die Chunks sind nur ein Retrieval-Artefakt und erscheinen NICHT im Wissensgraphen.
CHUNKING_ENABLED=true
CHUNKING_MAX_CHARS=1200
CHUNKING_OVERLAP_CHARS=150

# ── Feedback / Konfidenz-Decay (Vergessenskurve) ────────────────────
# Regeln, deren letztes Feedback (TDK-Pass, Nutzer-Signal, Compliance) älter wird, fallen beim
# täglichen Recalc anteilig Richtung neutral (1.0) zurück — altes Wissen "verblasst".
# Halbwertszeit in Tagen; <= 0 schaltet den Decay ab.
FEEDBACK_DECAY_HALFLIFE_DAYS=90

# ── LLM-Enrichment (optional) ───────────────────────────────────────
# Aktivieren: INGESTION_ENRICHER=llm und Provider/Key setzen.
INGESTION_ENRICHER=
INGESTION_LLM_PROVIDER=
INGESTION_LLM_MODEL=
INGESTION_LLM_BASE_URL=
INGESTION_LLM_API_KEY=

# ── MCP-Server (interne Tools → externe Agenten) ────────────────────
MCP_SERVER_ENABLED=true
# Default-Deny-Allowlist: nur diese Tools werden via MCP exponiert (alle read-only).
# Optional read-only zuschaltbar: analyze_coverage (Coverage-/Lücken-Report), z. B.:
#   MCP_EXPOSED_TOOLS=search_memory,list_memory,analyze_coverage
MCP_EXPOSED_TOOLS=search_memory,list_memory
# Schreib-Tools (manage_*) sind über MCP standardmäßig gesperrt — angebundene LLMs sind read-only.
# Nur für vertrauenswürdige Setups auf true setzen.
MCP_ALLOW_WRITE_TOOLS=

# ── Auth (lokal) ────────────────────────────────────────────────────
# Leer = loopback ohne Auth. Gesetzt = `Authorization: Bearer <token>` (oder ?token=)
# wird für /api/akg/* und /mcp verlangt.
EDDA_AUTH_TOKEN=

# ── TDK-Sandbox ─────────────────────────────────────────────────────
# docker (braucht gemounteten /var/run/docker.sock) | wasm (lokaler Python-Subprozess) | null
TDK_SANDBOX_TYPE=docker

# ── Web-Host (nur lokal binden) ─────────────────────────────────────
ASPNETCORE_URLS=http://127.0.0.1:8080
