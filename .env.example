# ── Edda — lokale Konfiguration ──────────────────────────────
# Kopiere diese Datei nach `.env` und passe die Werte an. `.env` ist git-ignoriert.

# ── Netzwerk (Docker-Deploy via install.sh / docker compose) ───────
# Bind-Adresse: 127.0.0.1 = nur lokal · 0.0.0.0 = alle Interfaces (remote erreichbar)
EDDA_BIND=127.0.0.1
EDDA_PORT=8080

# ── Graph-Datenbank ─────────────────────────────────────────────────
# neo4j (Default, nativer Vektorindex) | memgraph (leichter, App-seitiger Cosine-Fallback)
GRAPH_PROVIDER=neo4j
NEO4J_URI=bolt://neo4j:7687
# ⚠ SICHERHEIT: 'none' startet Neo4j OHNE Authentifizierung — nur für rein lokalen Loopback-Betrieb!
# Wird der Bolt-Port (7687) exponiert, steht die DB OFFEN. Für Server-/Remote-Betrieb den Platzhalter
# ersetzen: NEO4J_AUTH=neo4j/<starkes-passwort> UND dasselbe Passwort unten als NEO4J_PASSWORD setzen.
# Die Install-Skripte (install.sh/ps1) erzeugen hierfür automatisch ein Zufallspasswort.
NEO4J_AUTH=none
NEO4J_USERNAME=neo4j
# App-Login: basic = mit NEO4J_USERNAME/NEO4J_PASSWORD anmelden · none = ohne Zugangsdaten (loggt
# beim Start eine Sicherheitswarnung). Passend zu NEO4J_AUTH wählen.
NEO4J_AUTH_MODE=basic
NEO4J_PASSWORD=

# ── Embeddings ──────────────────────────────────────────────────────
# Provider: openai | google | voyage | ollama | custom | bedrock | null
# null = ohne semantische Suche (reines Keyword-Retrieval, kein API-Key nötig).
EMBEDDING_PROVIDER=null
OPENAI_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=
# Generischer Fallback-Key (greift für jeden HTTP-Provider, wenn der spezifische leer ist).
# Für bedrock: AWS Secret Access Key.
EMBEDDING_API_KEY=
# Für ollama/custom (lokales Embedding). Stack-internes Ollama (install.sh/ps1 "Lokales Embedding"):
#   COMPOSE_PROFILES=local-embeddings · EMBEDDING_PROVIDER=ollama · EMBEDDING_BASE_URL=http://ollama:11434
#   Modell dann z. B. bge-m3 (wird vom Skript via `ollama pull` gezogen).
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=
# Für bedrock (AWS): Region + Access Key ID. Bleiben beide AWS-Werte leer, nutzt das SDK die
# Default-Credential-Chain (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY, Profil oder Instanz-Rolle).
EMBEDDING_REGION=
EMBEDDING_ACCESS_KEY_ID=

# ── Chunking (adaptive Dokument-Zerlegung) ──────────────────────────
# Grosse Dokumente werden vor dem Embedding nach Stil (Prosa/Markdown/Code/Tabellen) in Chunks zerlegt.
# Die Chunks sind nur ein Retrieval-Artefakt und erscheinen NICHT im Wissensgraphen.
CHUNKING_ENABLED=true
CHUNKING_MAX_CHARS=1200
CHUNKING_OVERLAP_CHARS=150

# ── Retrieval-Tuning (Schwellwerte/Top-K der Hybrid-Suche) ──────────
# Feinjustierung ohne Rebuild. Leerer/nicht-numerischer/nicht-positiver Wert = Default (bisheriges
# Verhalten). Werte hier entsprechen exakt den bisherigen Defaults.
# Semantische Mindest-Ähnlichkeit (Cosine); Treffer darunter werden verworfen:
RETRIEVAL_SIMILARITY_THRESHOLD=0.5
# Anzahl der Nachbar-Chunks, die aus dem Vektorindex geholt werden:
RETRIEVAL_VECTOR_TOP_K=100
# MMR: Anzahl der Top-Kandidaten, die diversifiziert werden:
RETRIEVAL_MMR_TOP_N=15
# MMR-Lambda (1.0 = nur Relevanz, 0.0 = nur Diversität):
RETRIEVAL_MMR_LAMBDA=0.7
# Mindest-Ähnlichkeit eines Head-Zentroids für die Stage-1-Vorfilterung (ADR-0009):
RETRIEVAL_HEAD_THRESHOLD=0.4
# Obergrenze der Kandidaten, die der app-seitige Cosine-Fallback bewertet, wenn KEIN
# nativer Vektorindex verfügbar ist (z. B. Memgraph). Deckelt den O(N)-Fallback; darüber
# werden nur die keyword-stärksten Kandidaten behalten. Auf dem schnellen Index-Pfad ohne Wirkung:
RETRIEVAL_FALLBACK_MAX_CANDIDATES=500

# ── Feedback / Konfidenz-Decay (Vergessenskurve) ────────────────────
# Regeln, deren letztes Feedback (TDK-Pass, Nutzer-Signal, Compliance) älter wird, fallen beim
# täglichen Recalc anteilig Richtung neutral (1.0) zurück — altes Wissen "verblasst".
# Halbwertszeit in Tagen; <= 0 schaltet den Decay ab.
FEEDBACK_DECAY_HALFLIFE_DAYS=90

# Periodische Gedächtnis-Konsolidierung (C10): ein opt-in Hintergrunddienst räumt je Nutzer die
# episodischen Memories auf (normalisierte Duplikate entfernen, verblasste Einträge vergessen) — sonst
# passiert das nur bei manuellem consolidate_memory-Aufruf. Intervall in Stunden; 0/leer = AUS (Default).
MEMORY_CONSOLIDATION_INTERVAL_HOURS=0

# Kontradiktions-Erkennung im episodischen Gedächtnis (C3): beim remember wird ein neuer Fakt mit
# stark überlappenden bestehenden Memories desselben Nutzers verglichen (Token-Jaccard). Liegt die
# Überlappung über diesem Schwellwert, markiert der neue Fakt die alten als abgelöst (SUPERSEDES-Kante)
# und recall wertet abgelöste Memories im Ranking ab. Default 0.6; ein Wert > 1.0 schaltet die Erkennung ab.
MEMORY_SUPERSEDE_JACCARD=0.6

# ── LLM-Enrichment (optional) ───────────────────────────────────────
# Aktivieren: INGESTION_ENRICHER=llm und Provider/Key setzen.
INGESTION_ENRICHER=
INGESTION_LLM_PROVIDER=
INGESTION_LLM_MODEL=
INGESTION_LLM_BASE_URL=
INGESTION_LLM_API_KEY=

# Auto-Entity-Extraktion (LightRAG-Stil) beim Ingest, getrennt vom Enricher, opt-in.
# true = jedes ingestierte Item wird zusaetzlich auf typisierte Entitaeten/Relationen extrahiert
# (nutzt denselben LLM-Provider; braucht INGESTION_LLM_*). Default leer = AUS.
INGESTION_ENTITY_EXTRACTION=

# Maximale Textlänge (Zeichen) für den Entity-Ingest-Endpoint POST /api/akg/entities/ingest.
# Schützt vor leeren/riesigen Texten, die sinnlose LLM-Kosten verursachen: leerer oder zu langer
# Text → HTTP 400. Leerer/nicht-numerischer/nicht-positiver Wert hier = Default 20000.
INGESTION_MAX_TEXT_CHARS=20000

# Import fremder Wissens-Bundles (JSON): TDK-Validatoren sind ausführbarer Python-Code. Standardmäßig
# wird `validatorScript` beim Bundle-Import ENTFERNT, damit Fremd-Bundles keine Validatoren einschleusen
# (analog zur Vektor-Hygiene). Nur für vertrauenswürdige Bundles auf true setzen. Default leer = AUS = strippen.
IMPORT_ALLOW_VALIDATORS=

# ── MCP-Server (interne Tools → externe Agenten) ────────────────────
MCP_SERVER_ENABLED=true
# Default-Deny-Allowlist: nur diese Tools werden via MCP exponiert (alle read-only).
# Optional read-only zuschaltbar: analyze_coverage (Coverage-/Lücken-Report), z. B.:
#   MCP_EXPOSED_TOOLS=search_memory,list_memory,analyze_coverage
MCP_EXPOSED_TOOLS=search_memory,list_memory
# Schreib-Tools (manage_*) sind über MCP standardmäßig gesperrt — angebundene LLMs sind read-only.
# Nur für vertrauenswürdige Setups auf true setzen.
MCP_ALLOW_WRITE_TOOLS=

# ── Auth (lokal) ────────────────────────────────────────────────────
# Leer = loopback ohne Auth. Gesetzt = `Authorization: Bearer <token>` (oder ?token=)
# wird für /api/akg/* und /mcp verlangt.
EDDA_AUTH_TOKEN=

# Sicherheits-Guard (A4): Bindet Edda an eine Nicht-Loopback-Adresse (EDDA_BIND=0.0.0.0) OHNE
# gesetzten EDDA_AUTH_TOKEN, verweigert die App den Start (Fail-Fast) — sonst wäre die API+UI
# unauthentifiziert aus dem Netz erreichbar. true = Absicherung bewusst aushebeln (nur wenn ein
# vorgelagerter Reverse-Proxy/Firewall die Authentifizierung übernimmt). Leer/false = Guard aktiv.
EDDA_ALLOW_INSECURE_REMOTE=

# Vertrauenswürdige Reverse-Proxys (A5): kommagetrennte Proxy-IPs, deren X-Forwarded-For/-Proto-Header
# Edda auswertet, um die echte Client-IP + das Schema (http/https) hinter dem Proxy zu ermitteln
# (z. B. für das Rate-Limiting je Client-IP). NUR die hier gelisteten Proxys werden vertraut — sonst
# könnte ein Client seine Quell-IP fälschen. Leer = Forwarded-Header werden ignoriert (sicherer Default;
# RemoteIpAddress bleibt der direkte Peer). Beispiel: EDDA_TRUSTED_PROXIES=127.0.0.1,::1
EDDA_TRUSTED_PROXIES=

# Rate-Limiting für /api/* und /mcp (Schutz vor Token-Brute-Force / Request-Flut): erlaubte Requests
# pro Minute je Client-IP (Fixed-Window). 0 oder leer = AUS (unbegrenzt, bisheriges Verhalten).
# Für exponierten Betrieb empfohlen, z. B. 100. Die interaktive UI (Blazor-Circuit) ist ausgenommen.
EDDA_RATE_LIMIT_PER_MINUTE=0

# ── TDK-Sandbox ─────────────────────────────────────────────────────
# docker (braucht gemounteten /var/run/docker.sock) | wasm (lokaler Python-Subprozess) | null
TDK_SANDBOX_TYPE=docker

# ── Web-Host (nur lokal binden) ─────────────────────────────────────
ASPNETCORE_URLS=http://127.0.0.1:8080
